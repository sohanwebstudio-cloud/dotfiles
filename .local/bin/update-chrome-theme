#!/usr/bin/env python3
"""Generate Chrome theme from pywal colors and recharger via chrome://restart."""

import json
import os
import subprocess
import sys

THEME_DIR = os.path.expanduser('~/.local/share/chrome-wal-theme')
COLORS_FILE = os.path.expanduser('~/.cache/wal/colors.json')


def hex_to_rgb(h: str) -> list:
    h = h.lstrip('#')
    return [int(h[i:i+2], 16) for i in (0, 2, 4)]


def generate_manifest():
    with open(COLORS_FILE) as f:
        wal = json.load(f)

    bg = hex_to_rgb(wal['special']['background'])
    fg = hex_to_rgb(wal['special']['foreground'])
    c0 = hex_to_rgb(wal['colors']['color0'])
    c8 = hex_to_rgb(wal['colors']['color8'])

    manifest = {
        "manifest_version": 3,
        "name": "Wal Theme",
        "version": "1.0",
        "theme": {
            "colors": {
                "frame":               c0,
                "frame_inactive":      c0,
                "toolbar":             bg,
                "tab_text":            fg,
                "tab_background_text": c8,
                "bookmark_text":       fg,
                "ntp_background":      bg,
                "ntp_text":            fg,
                "omnibox_background":  c0,
                "omnibox_text":        fg,
                "button_background":   c0,
            },
            "tints": {
                "buttons": [-1, -1, -1]
            }
        }
    }

    os.makedirs(THEME_DIR, exist_ok=True)
    with open(f'{THEME_DIR}/manifest.json', 'w') as f:
        json.dump(manifest, f, indent=2)

    print('✓ Manifest généré')


def reload_chrome():
    """Recharge Chrome via chrome://restart (préserve la session)."""
    result = subprocess.run(
        ['pgrep', '-c', 'chrome'],
        capture_output=True, text=True
    )
    if result.returncode != 0:
        print('Chrome non ouvert — le thème sera appliqué au prochain lancement')
        return

    subprocess.Popen(
        ['google-chrome', 'chrome://restart'],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL
    )
    print('✓ Chrome redémarre avec le nouveau thème (session préservée)')


if __name__ == '__main__':
    generate_manifest()
    reload_chrome()
