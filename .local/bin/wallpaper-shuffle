#!/bin/bash
WALLPAPER_DIR="/home/sohan/Pictures/fond d'ecran"
IMG=$(find "$WALLPAPER_DIR" -maxdepth 1 -type f \( -iname "*.png" -o -iname "*.jpg" -o -iname "*.jpeg" -o -iname "*.webp" \) | shuf -n 1)
[ -z "$IMG" ] && exit 1
URI="file://$(printf '%s' "$IMG" | sed 's/ /%20/g')"
gsettings set org.gnome.desktop.background picture-uri "$URI"
gsettings set org.gnome.desktop.background picture-uri-dark "$URI"
gsettings set org.gnome.desktop.background picture-options 'zoom'
