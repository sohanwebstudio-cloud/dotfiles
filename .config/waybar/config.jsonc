{
    "layer": "top",
    "position": "top",
    "height": 32,
    "spacing": 4,
    "margin-top": 8,
    "margin-left": 8,
    "margin-right": 8,

    "modules-left": ["sway/workspaces", "sway/window"],
    "modules-center": ["clock"],
    "modules-right": ["custom/khal", "custom/power-profile", "pulseaudio", "bluetooth", "network", "cpu", "memory", "battery", "tray", "custom/power"],

    "sway/workspaces": {
        "format": "{id}",
        "on-click": "activate"
    },

    "sway/window": {
        "max-length": 60
    },

    "clock": {
        "format": "{:%H:%M}",
        "format-alt": "{:%a %d %b %Y  %H:%M}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "cpu": {
        "format": "  {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "  {used:0.1f}G",
        "interval": 5
    },

    "battery": {
        "states": { "warning": 30, "critical": 15 },
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ¼", "َ°پ¾", "َ°پ؟", "َ°‚پ", "َ°‚‚", "َ°پ¹"]
    },

    "bluetooth": {
        "format": "َ°‚¯",
        "format-connected": "َ°‚± {device_alias}",
        "format-disabled": "َ°‚²",
        "format-off": "َ°‚²",
        "tooltip-format": "{controller_alias} â€” {controller_address}",
        "tooltip-format-connected": "{controller_alias}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "kitty --title bluetuith bluetuith-wal"
    },

    "network": {
        "format-wifi": "  {essid}",
        "format-ethernet": "َ°ˆ€  {ipaddr}",
        "format-disconnected": "َ°¤­ ",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "on-click": "kitty --title nmtui nmtui-wal"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°‌ں ",
        "format-icons": { "default": ["َ°•؟", "َ°–€", "َ°•¾"] },
        "on-click": "kitty --title pulsemixer pulsemixer",
        "scroll-step": 5
    },

    "tray": {
        "spacing": 8
    },

    "custom/power": {
        "format": "âڈ»",
        "on-click": "/home/sohan/.local/bin/power-menu",
        "tooltip": false
    },

    "custom/khal": {
        "exec": "/home/sohan/.local/bin/waybar-khal",
        "return-type": "json",
        "interval": 300,
        "on-click": "/home/sohan/.local/bin/khal-popup",
        "tooltip": true
    },

    "custom/power-profile": {
        "exec": "/home/sohan/.local/bin/power-profile-waybar",
        "return-type": "json",
        "interval": 5,
        "on-click": "/home/sohan/.local/bin/power-profile-cycle",
        "tooltip": true
    }
}
