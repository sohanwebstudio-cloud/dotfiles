# Font
font_family      JetBrains Mono
bold_font        JetBrains Mono Bold
font_size        13.0

# Padding
window_padding_width 12

# Curseur
cursor_shape block
cursor_blink_interval 0

# Couleurs — thème sombre hacker
background            #0d0d0d
foreground            #e0e0e0
selection_background  #3a3a3a
selection_foreground  #ffffff

# Noir
color0  #1a1a1a
color8  #444444

# Rouge (sudo, erreurs)
color1  #cc3333
color9  #ff4444

# Vert (active, running)
color2  #44aa44
color10 #66cc66

# Jaune (enabled, warnings)
color3  #cc8800
color11 #ffaa00

# Bleu
color4  #3366cc
color12 #4488ff

# Magenta
color5  #993399
color13 #cc44cc

# Cyan (paths, commandes)
color6  #2299aa
color14 #33bbcc

# Blanc
color7  #cccccc
color15 #ffffff

# Onglets
tab_bar_style powerline
tab_powerline_style angled
active_tab_background   #cc3333
active_tab_foreground   #ffffff
inactive_tab_background #1a1a1a
inactive_tab_foreground #666666

# Divers
scrollback_lines 10000
enable_audio_bell no
